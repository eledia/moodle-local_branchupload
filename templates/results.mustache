{{!
    @template local_branchupload/results

    Results of CSV processing after upload.

    Context variables required for this template:
    * stats - object with created, updated, suspended, deleted, skipped, errors counts
    * rows - array of row objects with rownumber, email, branch, orgunit, lastname, firstname,
             status, statusmessage, info
    * headers - object with email, branch, orgunit, lastname, firstname, remove,
                cohorts, oldemail — the configured CSV column headers, used as
                table column titles
    * backurl - string, URL to return to upload page

    @package local_branchupload
    @author Christopher Reimann <christopher.reimann@eledia.de>
    @copyright 2026 eLeDia GmbH, Berlin https://eledia.de
    @license http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
}}

<div class="local-branchupload-results">

    <h2 class="visually-hidden">{{#str}}results_title, local_branchupload{{/str}}</h2>

    {{! Step indicator — semantic ordered list with aria-current on the active step. }}
    <ol class="local-branchupload-steps list-unstyled d-flex justify-content-center align-items-center gap-2 mb-4"
        aria-label="{{#str}}step_indicator_label, local_branchupload{{/str}}">
        <li>
            <span class="badge bg-success rounded-pill px-3 py-2">
                <span class="visually-hidden">{{#str}}step_completed, local_branchupload{{/str}}: </span>
                1 {{#str}}uploadstep, local_branchupload{{/str}}
            </span>
        </li>
        <li aria-hidden="true" class="text-muted">&rarr;</li>
        <li>
            <span class="badge bg-success rounded-pill px-3 py-2">
                <span class="visually-hidden">{{#str}}step_completed, local_branchupload{{/str}}: </span>
                2 {{#str}}previewstep, local_branchupload{{/str}}
            </span>
        </li>
        <li aria-hidden="true" class="text-muted">&rarr;</li>
        <li aria-current="step">
            <span class="badge bg-primary rounded-pill px-3 py-2">
                <span class="visually-hidden">{{#str}}step_current, local_branchupload{{/str}}: </span>
                3 {{#str}}resultstep, local_branchupload{{/str}}
            </span>
        </li>
    </ol>

    {{! Summary statistics cards }}
    <div class="d-flex flex-wrap gap-3 mb-4">
        <div class="card flex-fill text-center border-success">
            <div class="card-body py-3">
                <div class="h3 mb-1 text-success">{{stats.created}}</div>
                <small class="text-muted fw-bold">{{#str}}results_created, local_branchupload{{/str}}</small>
            </div>
        </div>
        <div class="card flex-fill text-center border-info">
            <div class="card-body py-3">
                <div class="h3 mb-1 text-info">{{stats.updated}}</div>
                <small class="text-muted fw-bold">{{#str}}results_updated, local_branchupload{{/str}}</small>
            </div>
        </div>
        <div class="card flex-fill text-center border-warning">
            <div class="card-body py-3">
                <div class="h3 mb-1 text-warning">{{stats.suspended}}</div>
                <small class="text-muted fw-bold">{{#str}}results_suspended, local_branchupload{{/str}}</small>
            </div>
        </div>
        <div class="card flex-fill text-center border-dark">
            <div class="card-body py-3">
                <div class="h3 mb-1">{{stats.deleted}}</div>
                <small class="text-muted fw-bold">{{#str}}results_deleted, local_branchupload{{/str}}</small>
            </div>
        </div>
        <div class="card flex-fill text-center border-secondary">
            <div class="card-body py-3">
                <div class="h3 mb-1 text-secondary">{{stats.skipped}}</div>
                <small class="text-muted fw-bold">{{#str}}results_skipped, local_branchupload{{/str}}</small>
            </div>
        </div>
        <div class="card flex-fill text-center border-danger">
            <div class="card-body py-3">
                <div class="h3 mb-1 text-danger">{{stats.errors}}</div>
                <small class="text-muted fw-bold">{{#str}}results_errors, local_branchupload{{/str}}</small>
            </div>
        </div>
    </div>

    {{! Results table }}
    <div class="table-responsive">
        <table class="table table-striped table-hover generaltable">
            <caption class="visually-hidden">{{#str}}results_title, local_branchupload{{/str}}</caption>
            <thead class="table-dark">
                <tr>
                    <th scope="col" aria-label="{{#str}}header_rownumber, local_branchupload{{/str}}">#</th>
                    <th scope="col">{{headers.email}}</th>
                    <th scope="col">{{headers.lastname}}</th>
                    <th scope="col">{{headers.firstname}}</th>
                    <th scope="col">{{headers.branch}}</th>
                    <th scope="col">{{#str}}header_status, local_branchupload{{/str}}</th>
                    <th scope="col">{{#str}}header_details, local_branchupload{{/str}}</th>
                </tr>
            </thead>
            <tbody>
                {{#rows}}
                <tr class="
                    {{#iscreated}}table-success{{/iscreated}}
                    {{#isupdated}}{{/isupdated}}
                    {{#issuspended}}table-warning{{/issuspended}}
                    {{#isdeleted}}table-secondary{{/isdeleted}}
                    {{#isskipped}}table-light{{/isskipped}}
                    {{#iserror}}table-danger{{/iserror}}
                ">
                    <th scope="row" class="fw-normal">{{rownumber}}</th>
                    <td>{{email}}</td>
                    <td>{{lastname}}</td>
                    <td>{{firstname}}</td>
                    <td>{{branch}}</td>
                    <td>
                        {{#iscreated}}<span class="badge bg-success"><i class="fa fa-plus-circle" aria-hidden="true"></i> {{#str}}result_created, local_branchupload{{/str}}</span>{{/iscreated}}
                        {{#isupdated}}<span class="badge bg-info text-dark"><i class="fa fa-pencil" aria-hidden="true"></i> {{#str}}result_updated, local_branchupload{{/str}}</span>{{/isupdated}}
                        {{#issuspended}}<span class="badge bg-warning text-dark"><i class="fa fa-ban" aria-hidden="true"></i> {{#str}}result_suspended, local_branchupload{{/str}}</span>{{/issuspended}}
                        {{#isdeleted}}<span class="badge bg-dark"><i class="fa fa-trash" aria-hidden="true"></i> {{#str}}result_deleted, local_branchupload{{/str}}</span>{{/isdeleted}}
                        {{#isskipped}}<span class="badge bg-secondary"><i class="fa fa-forward" aria-hidden="true"></i> {{#str}}result_skipped, local_branchupload{{/str}}</span>{{/isskipped}}
                        {{#iserror}}<span class="badge bg-danger"><i class="fa fa-times-circle" aria-hidden="true"></i> {{#str}}result_error, local_branchupload{{/str}}</span>{{/iserror}}
                    </td>
                    <td>
                        {{statusmessage}}
                        {{#info}}<br><small class="text-muted">{{info}}</small>{{/info}}
                    </td>
                </tr>
                {{/rows}}
            </tbody>
        </table>
    </div>

    {{! Back button }}
    <div class="d-flex justify-content-end mt-3">
        <a href="{{backurl}}" class="btn btn-primary">
            <i class="fa fa-upload me-1" aria-hidden="true"></i>
            {{#str}}results_back, local_branchupload{{/str}}
        </a>
    </div>

</div>
